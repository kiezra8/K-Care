<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>K'Care - Premium Home Healthcare</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        :root {
            --primary: #2D5A5A;
            --secondary: #D4AF37;
            --accent: #E8B4B8;
            --bg: #FAFAFA;
            --text: #2C3E50;
            --white: #FFFFFF;
            --shadow: rgba(0, 0, 0, 0.08);
        }

        body {
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            padding-bottom: 85px;
            max-width: 480px;
            margin: 0 auto;
            background: var(--white);
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, var(--primary) 0%, #3D7A7A 100%);
            padding: 12px 16px;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 20px var(--shadow);
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .logo {
            font-size: 26px;
            font-weight: 700;
            color: var(--white);
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--secondary);
        }

        .search-container {
            position: relative;
            width: 100%;
        }

        .search-bar {
            width: 100%;
            padding: 11px 42px 11px 16px;
            border: none;
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.95);
            font-size: 14px;
            outline: none;
            transition: all 0.3s;
        }

        .search-bar:focus {
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.3);
        }

        .search-icon {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary);
            font-size: 16px;
        }

        /* Animations Section - Shein Style */
        .hero-slider {
            position: relative;
            height: 220px;
            overflow: hidden;
            margin: 16px 0;
        }

        .slide {
            position: absolute;
            width: 100%;
            height: 100%;
            opacity: 0;
            transition: opacity 0.8s ease-in-out;
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 12px;
            border-radius: 16px;
            overflow: hidden;
        }

        .slide.active {
            opacity: 1;
        }

        .slide::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(45, 90, 90, 0.85) 0%, rgba(45, 90, 90, 0.4) 100%);
        }

        .slide-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: var(--white);
            padding: 24px;
            animation: slideUp 0.8s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .slide-content h2 {
            font-size: 24px;
            margin-bottom: 8px;
            font-weight: 700;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }

        .slide-content p {
            font-size: 14px;
            opacity: 0.95;
            line-height: 1.5;
        }

        .slide-indicators {
            position: absolute;
            bottom: 12px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 6px;
            z-index: 3;
        }

        .indicator {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.5);
            cursor: pointer;
            transition: all 0.3s;
        }

        .indicator.active {
            background: var(--secondary);
            width: 20px;
            border-radius: 3px;
        }

        /* Categories Section */
        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text);
            margin: 24px 16px 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, var(--secondary), transparent);
            margin-left: 8px;
        }

        .categories-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            padding: 0 16px;
        }

        .category-card {
            background: var(--white);
            border-radius: 16px;
            aspect-ratio: 4/5;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
            padding: 16px;
            box-shadow: 0 4px 15px var(--shadow);
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
            position: relative;
            overflow: hidden;
            background-size: cover;
            background-position: center;
        }

        .category-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to top, rgba(45, 90, 90, 0.9) 0%, rgba(45, 90, 90, 0.3) 50%, transparent 100%);
            z-index: 1;
        }

        .category-card:hover::before {
            background: linear-gradient(to top, rgba(45, 90, 90, 0.95) 0%, rgba(45, 90, 90, 0.4) 50%, transparent 100%);
        }

        .category-card:hover {
            transform: translateY(-3px);
            border-color: var(--secondary);
            box-shadow: 0 8px 25px rgba(45, 90, 90, 0.15);
        }

        .category-name {
            font-size: 14px;
            font-weight: 700;
            color: var(--white);
            text-align: center;
            z-index: 2;
            line-height: 1.3;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        }

        /* Professionals Section */
        .professionals-list {
            padding: 0 16px;
            display: grid;
            gap: 16px;
        }

        .professional-card {
            background: var(--white);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 15px var(--shadow);
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
        }

        .professional-card:active {
            transform: scale(0.98);
        }

        .prof-image-container {
            position: relative;
            height: 240px;
            overflow: hidden;
        }

        .prof-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s;
        }

        .professional-card:active .prof-image {
            transform: scale(1.02);
        }

        .prof-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(45, 90, 90, 0.95), transparent);
            padding: 60px 16px 16px;
            color: var(--white);
        }

        .prof-name {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .prof-profession {
            font-size: 14px;
            opacity: 0.9;
            margin-bottom: 12px;
        }

        .more-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--secondary);
            color: var(--white);
            padding: 8px 20px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.3s;
        }

        .more-btn:active {
            background: #C49F27;
            transform: scale(0.95);
        }

        /* Professional Detail Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            z-index: 2000;
            overflow-y: auto;
            animation: fadeIn 0.3s;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .modal-content {
            background: var(--white);
            min-height: 100vh;
            position: relative;
            animation: slideUpModal 0.4s;
            max-width: 480px;
            margin: 0 auto;
        }

        @keyframes slideUpModal {
            from {
                transform: translateY(100%);
            }

            to {
                transform: translateY(0);
            }
        }

        .modal-header {
            position: relative;
            height: 300px;
            overflow: hidden;
        }

        .modal-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .modal-close {
            position: absolute;
            top: 16px;
            left: 16px;
            width: 40px;
            height: 40px;
            background: var(--white);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 18px;
            color: var(--text);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            z-index: 10;
            transition: all 0.3s;
        }

        .modal-close:active {
            transform: rotate(90deg);
            background: var(--secondary);
            color: var(--white);
        }

        .modal-body {
            padding: 24px 16px;
            margin-top: -40px;
            position: relative;
            background: var(--white);
            border-radius: 24px 24px 0 0;
        }

        .modal-name {
            font-size: 24px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 4px;
        }

        .modal-profession {
            color: var(--primary);
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .cv-section {
            background: var(--bg);
            padding: 20px;
            border-radius: 16px;
            margin-bottom: 20px;
        }

        .cv-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .cv-item {
            margin-bottom: 12px;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .cv-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .cv-label {
            font-size: 12px;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .cv-value {
            font-size: 14px;
            color: var(--text);
            line-height: 1.5;
        }

        .contact-section {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .contact-btn {
            flex: 1;
            padding: 16px;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s;
            text-decoration: none;
        }

        .contact-btn:active {
            transform: scale(0.97);
        }

        .whatsapp-btn {
            background: #25D366;
            color: var(--white);
        }

        .call-btn {
            background: var(--primary);
            color: var(--white);
        }

        /* Chat Modal */
        .chat-modal {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            z-index: 3000;
            border-radius: 24px 24px 0 0;
            padding: 24px 16px;
            box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.15);
            animation: slideUpChat 0.3s;
            max-width: 480px;
            margin: 0 auto;
        }

        @keyframes slideUpChat {
            from {
                transform: translateY(100%);
            }

            to {
                transform: translateY(0);
            }
        }

        .chat-modal-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .chat-modal-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }

        .chat-modal-subtitle {
            font-size: 14px;
            color: #666;
        }

        .chat-options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .chat-option {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
        }

        .chat-option:active {
            transform: scale(0.98);
        }

        .chat-option-whatsapp {
            background: #DCF8C6;
        }

        .chat-option-call {
            background: #E3F2FD;
        }

        .chat-option-icon {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--white);
        }

        .chat-option-whatsapp .chat-option-icon {
            background: #25D366;
        }

        .chat-option-call .chat-option-icon {
            background: var(--primary);
        }

        .chat-option-text {
            flex: 1;
        }

        .chat-option-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 2px;
        }

        .chat-option-desc {
            font-size: 13px;
            color: #666;
        }

        .chat-close {
            position: absolute;
            top: 16px;
            right: 16px;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--bg);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 18px;
            color: var(--text);
            border: none;
        }

        /* Bottom Navigation */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            display: flex;
            justify-content: space-around;
            padding: 10px 0;
            box-shadow: 0 -4px 20px var(--shadow);
            z-index: 1000;
            max-width: 480px;
            margin: 0 auto;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            padding: 4px 16px;
            transition: all 0.3s;
            color: #999;
        }

        .nav-item.active {
            color: var(--primary);
        }

        .nav-item i {
            font-size: 20px;
            transition: all 0.3s;
        }

        .nav-item.active i {
            color: var(--secondary);
            transform: translateY(-2px);
        }

        .nav-item span {
            font-size: 11px;
            font-weight: 600;
        }

        /* Page Sections */
        .page {
            display: none;
            animation: fadeIn 0.4s;
        }

        .page.active {
            display: block;
        }

        /* Overlay for chat modal */
        .overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 2500;
        }

        /* Filter indicator */
        .filter-indicator {
            background: var(--primary);
            color: var(--white);
            padding: 8px 16px;
            margin: 0 16px 16px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 600;
        }

        .filter-indicator i {
            cursor: pointer;
            font-size: 12px;
        }

        /* Responsive */
        @media (max-width: 480px) {
            body {
                max-width: 100%;
            }

            .bottom-nav,
            .modal-content,
            .chat-modal {
                max-width: 100%;
            }
        }
    </style>
</head>

<body>

    <!-- Header -->
    <header class="header">
        <div class="header-top">
            <div class="logo">K'<span>Care</span></div>
        </div>
        <div class="search-container">
            <input type="text" class="search-bar" placeholder="Search nurses, midwives, services..." id="searchInput">
            <i class="fas fa-search search-icon"></i>
        </div>
    </header>

    <!-- Home Page -->
    <div id="homePage" class="page active">
        <!-- Hero Slider -->
        <div class="hero-slider">
            <div class="slide active"
                style="background-image: url('https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=800');">
                <div class="slide-content">
                    <h2>Quality Care at Home</h2>
                    <p>Experience professional healthcare in the comfort of your home</p>
                </div>
            </div>
            <div class="slide"
                style="background-image: url('https://images.unsplash.com/photo-1579684385127-1ef15d508118?w=800');">
                <div class="slide-content">
                    <h2>Our Premium Services</h2>
                    <p>Comprehensive healthcare solutions tailored to your needs</p>
                </div>
            </div>
            <div class="slide"
                style="background-image: url('https://images.unsplash.com/photo-1631217868264-e5b90bb7e133?w=800');">
                <div class="slide-content">
                    <h2>Trusted Professionals</h2>
                    <p>Certified nurses and midwives dedicated to compassionate care</p>
                </div>
            </div>
            <div class="slide-indicators">
                <span class="indicator active" onclick="currentSlide(0)"></span></html>
